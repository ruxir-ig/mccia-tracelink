{
  "name": "tracelink-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 migrations apply tracelink-db",
    "db:migrate:local": "wrangler d1 migrations apply tracelink-db --local",
    "db:seed": "wrangler d1 execute tracelink-db --file=scripts/seed.sql",
    "db:seed:local": "wrangler d1 execute tracelink-db --local --file=scripts/seed.sql",
    "db:generate": "tsx scripts/generate-seed.ts"
  },
  "dependencies": {
    "hono": "^4.7.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250401.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "wrangler": "^4.14.0"
  }
}
